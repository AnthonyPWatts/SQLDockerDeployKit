{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "databaseProvider": {
      "type": "string",
      "defaultValue": "sqlserver",
      "allowedValues": [
        "sqlserver",
        "postgres"
      ],
      "metadata": {
        "description": "Database provider to deploy. SQL Server remains the default."
      }
    },
    "saPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Database administrator password. SQL Server uses this for the sa account; PostgreSQL uses this for the postgres account."
      }
    }
  },
  "variables": {
    "providerSettings": {
      "sqlserver": {
        "image": "ghcr.io/anthonypwatts/sqldockerdeploykit/database-container:main",
        "port": 1433,
        "passwordEnvironmentVariable": "MSSQL_SA_PASSWORD"
      },
      "postgres": {
        "image": "ghcr.io/anthonypwatts/sqldockerdeploykit/database-container-postgres:main",
        "port": 5432,
        "passwordEnvironmentVariable": "POSTGRES_PASSWORD"
      }
    },
    "selectedProvider": "[variables('providerSettings')[parameters('databaseProvider')]]"
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2021-03-01",
      "name": "databasecontainergroup",
      "location": "uksouth",
      "properties": {
        "containers": [
          {
            "name": "databasecontainer",
            "properties": {
              "image": "[variables('selectedProvider').image]",
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGb": 2.0
                }
              },
              "environmentVariables": [
                {
                  "name": "[variables('selectedProvider').passwordEnvironmentVariable]",
                  "secureValue": "[parameters('saPassword')]"
                }
              ],
              "ports": [
                {
                  "port": "[variables('selectedProvider').port]"
                }
              ]
            }
          }
        ],
        "osType": "Linux",
        "restartPolicy": "OnFailure",
        "ipAddress": {
          "type": "Public",
          "ports": [
            {
              "protocol": "tcp",
              "port": "[variables('selectedProvider').port]"
            }
          ]
        }
      }
    }
  ]
}
